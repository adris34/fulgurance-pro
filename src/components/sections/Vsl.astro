---
import VideoBlock from "@/components/ui/VideoBlock.astro";
import CtaButton from "@/components/ui/CtaButton.astro";
---

<section id="vsl" class="border-b border-border-soft/60 bg-surface/40">
  <div class="mx-auto max-w-6xl px-6 py-20 text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
      La technologie Fulgurance <span class="brand-gradient-text">en conditions réelles</span>
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-zinc-400">
      Une séance complète filmée avec la combinaison PowerSuit — 30 minutes, un programme
      personnalisé, piloté depuis l&apos;application Fulgurance. Exactement ce que vivront
      vos clients dès leur première séance.
    </p>

    <div class="mx-auto mt-10 w-full max-w-5xl">
      <VideoBlock
        youtubeId="Mvv_ulaQP4A"
        label="Pilotez des séances individuelles ou de groupes"
        caption="Mise en place, encadrement collectif, pilotage en temps réel — la technologie expliquée en conditions réelles"
      />
    </div>

    <div class="mt-10">
      <CtaButton href="https://cal.eu/fulgurance-pro/decouverte-30min">Échanger avec notre équipe</CtaButton>
    </div>
  </div>
</section>
