---
import VideoBlock from "@/components/ui/VideoBlock.astro";
---

<section class="border-b border-border-soft/60 bg-surface/40">
  <div class="mx-auto max-w-6xl px-6 py-20 text-center">
    <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-soft bg-surface px-4 py-2 text-xs font-medium uppercase tracking-wider text-zinc-300">
      <span class="h-2 w-2 rounded-full brand-gradient" />
      M6 · Qui Veut Être Mon Associé — Saison 4
    </p>

    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
      Notre passage chez <span class="brand-gradient-text">QVEMA</span>
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-zinc-400">
      Fulgurance s&apos;est présenté devant les investisseurs de Qui Veut Être Mon Associé sur M6 —
      une reconnaissance qui confirme le sérieux et le potentiel de notre technologie d&apos;électrostimulation.
    </p>

    <div class="mx-auto mt-10 w-full max-w-5xl">
      <VideoBlock
        youtubeId="mCGyRberqaY"
        label="Le passage de Fulgurance dans Qui Veut Être Mon Associé"
        caption="Saison 4 — M6"
      />
    </div>
  </div>
</section>
